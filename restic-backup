#!/bin/bash
set -euo pipefail

# ==================== Configuration ====================
# Use flock with a lock file
LOCKFILE="/tmp/restic-backup.lock"

# Wait for lock (or fail immediately)
exec 200>"$LOCKFILE"
if ! flock -n 200; then
    echo -e "Restic backup already running. Exiting." >&2
    exit 1
fi

# Common restic backup options (DRY principle - no duplication)
# -o local.connections=8 : faster local repo I/O (assuming local backend)
# --exclude='*/.cache'   : always skip caches
CORES="$(nproc 2>/dev/null || getconf _NPROCESSORS_ONLN)"
declare -a RESTIC_BACKUP_BASE=(-o local.connections="$CORES" --iexclude='*/.cache')

run_restic() {
    if [ "$EUID" -ne 0 ]; then
        # Not root: escalate
        exec sudo bash -c '
            set -a
            source /etc/resticenv
            set +a
            exec restic "$@"
        ' -- "$@"
    else
        # Already root
        set -a
        source /etc/resticenv
        set +a
        exec restic "$@"
    fi
}

backup() {
    local tag="$1"
    shift
    local paths=()
    local extra_args=()
    while [[ "$#" -gt 0 ]]; do
        if [[ "$1" == --* ]]; then
            extra_args=("$@")
            break
        fi
        paths+=("$1")
        shift
    done
    if [[ "${#paths[@]}" -eq 0 ]]; then
        echo "Error: no paths provided"
        return 1
    fi
    echo -e "Backing up ${paths[@]}"
    run_restic backup "${paths[@]}" --tag "$tag" "${RESTIC_BACKUP_BASE[@]}" "${extra_args[@]}"
    echo -e "Backed up ${paths[@]}\n\n"
}

# ==================== Service-aware backups ====================
docker() {
    backup DockerArchPC "${HOME_DIR}/docker/" "/etc/docker" "/var/lib/docker/containers" "/var/lib/docker/network"
}

dockerstop() {
    echo -e "Stopping Docker\n"
    sudo systemctl stop docker.socket
}

dockerstart() {
    echo -e "Starting Docker\n"
    sudo systemctl start docker
}

immich() {
    backup Immich "/mnt/nvme/Documents/Media/Immich"
}

jellyfin() {
    echo -e "Stopping Jellyfin\n"
    sudo systemctl stop jellyfin
    backup Jellyfin "/var/lib/jellyfin/"
    sudo systemctl start jellyfin
    echo -e "Jellyfin restarted.\n"
}

# ==================== Main Backups ====================
# All backups now use the same `backup` function → consistent, DRY, and easy to extend
date
echo
backup HomeSon /home/ --iexclude='*/docker' --iexclude='*/target/debug/' --iexclude='*/target/release'
backup NVME /mnt/nvme/ --iexclude='*/docker' --iexclude='*/immich'
backup ArchPC_Snapshots /.snapshots/

# Service-specific backups
#dockerstop
#docker
#immich
#dockerstart
jellyfin

echo -e "Backup finished"
date
echo
